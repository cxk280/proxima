# Copy this file to `deploy/.env` and fill in your key.
#   cp deploy/.env.example deploy/.env
# `deploy/.env` is gitignored (the root .gitignore ignores `.env` everywhere),
# so your key never gets committed and never lands in a transcript.

# Vultr API key — https://my.vultr.com/settings/#settingsapi
VULTR_API_KEY=

# Anthropic API key — makes the voice agent a REAL Claude call (model claude-haiku-4-5,
# ~$0.001/turn, rate-capped). app-deploy.sh writes it into the app host's env; blank →
# the app's scripted fallback. Never committed or printed.
ANTHROPIC_API_KEY=

# --- Optional overrides (sensible defaults if left blank) ---

# Public hostname for the app host. Leave blank to auto-use a free
# <dash-ip>.sslip.io hostname (real DNS → free Let's Encrypt HTTPS, $0).
# Set a real domain here only if you have one pointed at the app host IP.
PROXIMA_DOMAIN=

# Local SSH public key injected into hosts so this machine can finish setup.
# Defaults to ~/.ssh/id_ed25519.pub.
PROXIMA_SSH_PUBKEY=
